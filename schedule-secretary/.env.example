# Schedule Secretary Environment Configuration

# Database
DATABASE_PATH=schedule_secretary.db

# Flask
SECRET_KEY=your-secret-key-change-in-production
HOST=0.0.0.0
PORT=5001

# Feishu (Lark) Configuration
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
