{
  "mcpServers": {
    "secretary-team": {
      "type": "stdio",
      "command": "python",
      "args": [
        "agents/mcp_server.py"
      ]
    }
  },
  "hooks": {
    "UserMessage": {
      "command": "python",
      "args": [
        ".claude/save_conversation.py",
        "user",
        "{message}"
      ]
    },
    "AssistantMessage": {
      "command": "python",
      "args": [
        ".claude/save_conversation.py",
        "assistant",
        "{message}"
      ]
    }
  }
}